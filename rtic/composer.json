{
    "name": "pushwing/rtic",
    "description": "rtic — Realtime Intercom (외부 공중 인터넷 → 자택 온프레미스 스피커, CodeIgniter 4 API)",
    "license": "proprietary",
    "type": "project",
    "require": {
        "php": "^8.2",
        "codeigniter4/framework": "^4.7",
        "firebase/php-jwt": "^7.0"
    },
    "require-dev": {
        "fakerphp/faker": "^1.9",
        "friendsofphp/php-cs-fixer": "^3.95",
        "mikey179/vfsstream": "^1.6",
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^10.5.16"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Config\\": "app/Config/"
        },
        "exclude-from-classmap": [
            "**/Database/Migrations/**"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\Support\\": "tests/_support"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "scripts": {
        "analyse": "phpstan analyse --memory-limit=512M",
        "test": "phpunit",
        "cs": "php-cs-fixer fix --dry-run --diff",
        "cs-fix": "php-cs-fixer fix",
        "check": [
            "@analyse",
            "@test"
        ],
        "ci": [
            "@cs",
            "@analyse",
            "@test"
        ]
    }
}
