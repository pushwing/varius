# ENVIRONMENT
#--------------------------------------------------------------------

# CI_ENVIRONMENT = production

#--------------------------------------------------------------------
# APP
#--------------------------------------------------------------------

# app.baseURL = ''
# If you have trouble with `.`, you could also use `_`.
# app_baseURL = ''
# app.forceGlobalSecureRequests = false
# app.CSPEnabled = false

#--------------------------------------------------------------------
# DATABASE
#--------------------------------------------------------------------

# 온프레미스 단일 서버, 소수 사용자 규모라 별도 DB 서버 없이 SQLite3 파일을 사용한다.
# 슬래시 없는 파일명이면 CI4가 자동으로 WRITEPATH를 붙인다(writable/database.db).
database.default.database = database.db
database.default.DBDriver = SQLite3

database.tests.database = :memory:
database.tests.DBDriver = SQLite3

#--------------------------------------------------------------------
# ENCRYPTION
#--------------------------------------------------------------------

# encryption.key =

#--------------------------------------------------------------------
# SESSION
#--------------------------------------------------------------------

# session.driver = 'CodeIgniter\Session\Handlers\FileHandler'
# session.savePath = null

#--------------------------------------------------------------------
# LOGGER
#--------------------------------------------------------------------

# logger.threshold = 4

#--------------------------------------------------------------------
# LiveKit (room 입장 토큰)
#--------------------------------------------------------------------
# rtic/livekit/.env의 LIVEKIT_KEYS(key: secret)와 apiKey/apiSecret이
# 반드시 동일한 값을 사용해야 한다.

# livekit.apiKey = change-me-api-key
# livekit.apiSecret = change-me-api-secret-at-least-32-bytes
# livekit.url = ws://localhost:7880
# livekit.tokenTtl = 300
# livekit.roomName = rtic-home

#--------------------------------------------------------------------
# TURN (coturn use-auth-secret credential) — 현재 미사용
#--------------------------------------------------------------------
# LiveKit 내장 TURN을 사용하기로 해 당장은 연동하지 않는다(이슈 #6).
# 외부 coturn(#5)을 다시 쓰게 되면 rtic/coturn/.env의 TURN_SECRET과
# 반드시 동일한 값을 사용해야 한다.

# turn.secret = your-secret-key-change-this-in-production
# turn.credentialTtl = 300
# turn.realm = rtic-home
