# 배포 시 /etc/rtic-daemon/env로 복사하고 실제 값으로 교체한다(커밋 금지).
# rtic/livekit/.env의 LIVEKIT_KEYS(key: secret)와 반드시 동일한 값을 사용한다.

RTIC_LIVEKIT_WS_URL=ws://localhost:7880
RTIC_LIVEKIT_API_KEY=change-me-api-key
RTIC_LIVEKIT_API_SECRET=change-me-api-secret-at-least-32-bytes
RTIC_LIVEKIT_ROOM_NAME=rtic-home

# 선택 — 생략 시 기본값 사용
# RTIC_DAEMON_IDENTITY=rtic-speaker
# RTIC_METRICS_PORT=9477

# 오디오 출력 sink (GStreamer element description).
# ⚠️ 실제 자택 서버 배포 시 반드시 확인·조정할 값 — 아래 두 가지가 핵심이다:
#
#   1) sync=false: WebRTC 실시간 오디오는 네트워크 지터로 타임스탬프가
#      불규칙해, 기본 sync=true면 alsasink가 클럭을 못 맞춰 소리가 아예
#      안 난다. 실시간 재생이므로 sync=false로 동기화를 꺼야 한다(기본값에
#      이미 포함).
#   2) device=plughw:N,M: `aplay -l`로 출력 카드/디바이스 번호를 확인해
#      맞춘다. raw `hw:` 대신 `plughw:`를 쓰면 ALSA가 샘플레이트·채널을
#      자동 변환해줘 포맷 불일치로 인한 무음을 피한다.
#
# 예: 카드 0, 디바이스 0의 아날로그 출력으로 낼 때
# RTIC_AUDIO_SINK=alsasink device=plughw:0,0 sync=false

# --- 양방향 인터콤(역방향: 자택 마이크 -> 앱) ---
# 자택 서버에 마이크가 연결되면 아래를 켜서 로컬 오디오를 LiveKit에
# 퍼블리시한다(앱이 수신·재생). 기본은 off라 스피커 전용 배포엔 영향 없다.
# 마이크 퍼블리셔는 오디오 수신기와 별개 참가자(`<identity>-mic`)로 접속한다.
# RTIC_MIC_ENABLED=true
#
# 마이크 캡처 소스 (GStreamer element description). 생략 시 autoaudiosrc가
# 시스템 기본 입력을 잡는다. 실서버에서는 `arecord -l`로 캡처 카드/디바이스
# 번호를 확인해 `alsasrc device=plughw:N,M`으로 지정한다. `hw:` 대신
# `plughw:`를 쓰면 ALSA가 샘플레이트·채널을 자동 변환해 포맷 불일치를 피한다.
# opus 인코딩은 livekitwebrtcsink가 내부에서 처리하므로 별도 인코더는 불필요.
# 예: 캡처 카드 1, 디바이스 0의 USB 마이크
# RTIC_AUDIO_SOURCE=alsasrc device=plughw:1,0
